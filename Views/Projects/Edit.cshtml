@model MzansiBuilds.Models.Project

@{
    ViewBag.Title = "Edit Project";
}

<!-- Constrained width matching the Create view layout -->
<div style="max-width: 620px; margin: 0 auto;">

    <!-- Page heading -->
    <div class="page-hero" style="padding: 16px 0 2px 0; margin-bottom: 16px;">
        <h2>Edit <span class="green-text">Project</span></h2>
        <p>Update your project details</p>
    </div>

    <!-- Edit project form - posts to ProjectsController.Edit (POST) -->
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <!-- Hidden field preserves the ProjectId across the POST so the controller knows which record to update -->
        @Html.HiddenFor(model => model.ProjectId)

        <!-- Summary of model-level validation errors -->
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="panel panel-default">
            <div class="panel-body" style="display: flex; flex-direction: column; gap: 16px;">

                <!-- Title - required -->
                <div>
                    <label class="control-label">Project Title</label>
                    @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                </div>

                <!-- Description -->
                <div>
                    <label class="control-label">Description</label>
                    @Html.TextAreaFor(model => model.Description, new { @class = "form-control", rows = "3" })
                    @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger" })
                </div>

                <!-- Stage dropdown - changing to Completed auto-adds project to Celebration Wall (handled in controller) -->
                <div>
                    <label class="control-label">Stage</label>
                    @Html.DropDownListFor(model => model.Stage,
                        new SelectList(new[] { "Idea", "In Progress", "MVP", "Completed" }, Model.Stage),
                        "-- Select Stage --",
                        new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Stage, "", new { @class = "text-danger" })
                    <small class="text-muted" style="margin-top: 6px; display: block;">
                        Setting stage to "Completed" will automatically add this project to the Celebration Wall
                    </small>
                </div>

                <!-- Support Needed - optional -->
                <div>
                    <label class="control-label">
                        Support Needed
                        <span style="color: rgba(255,255,255,0.3); font-weight: 400; text-transform: none; letter-spacing: 0;">(optional)</span>
                    </label>
                    @Html.TextAreaFor(model => model.SupportNeeded, new { @class = "form-control", rows = "2" })
                </div>

                <!-- Form action buttons - Cancel returns to the project's Details page -->
                <div style="display: flex; gap: 12px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.05);">
                    <input type="submit" value="Save Changes" class="btn btn-primary" />
                    @Html.ActionLink("Cancel", "Details", new { id = Model.ProjectId }, new { @class = "btn btn-default" })
                </div>

            </div>
        </div>
    }
</div>