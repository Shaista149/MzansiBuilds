@model MzansiBuilds.Models.Project

@{
    ViewBag.Title = "Delete Project";
}

<h2>Delete Project</h2>
<h3 class="text-danger">Are you sure you want to delete this project? This cannot be undone.</h3>

<div class="panel panel-danger">
    <div class="panel-heading">
        <h4 class="panel-title">@Model.Title</h4>
    </div>
    <div class="panel-body">
        <p>@Model.Description</p>
        <p><strong>Stage:</strong> @Model.Stage</p>
        <p><strong>Created:</strong> @Model.CreatedAt.ToString("dd MMM yyyy")</p>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <input type="submit" value="Yes, Delete Project" class="btn btn-danger" />
    @Html.ActionLink("Cancel", "Details", new { id = Model.ProjectId }, new { @class = "btn btn-default" })
}