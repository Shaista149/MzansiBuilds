@model MzansiBuilds.Models.Project

@{
    ViewBag.Title = "Delete Project";
}

<!-- Page heading -->
<div class="page-hero">
    <h2 style="color: #ef4444;">Delete Project</h2>
    <p>This action cannot be undone.</p>
</div>

<!-- Constrained width keeps the confirmation UI focused -->
<div style="max-width: 600px;">

    <!-- Danger-styled panel-->
    <div class="panel panel-danger">

        <!-- Project title shown so the user knows exactly what they're deleting -->
        <div class="panel-heading">
            <h3 class="panel-title">@Model.Title</h3>
        </div>

        <div class="panel-body">

            <!-- Project details for final review before deletion -->
            <p style="color: rgba(255,255,255,0.8);">@Model.Description</p>
            <p><strong style="color: rgba(255,255,255,0.5);">Stage:</strong> @Model.Stage</p>
            <p><strong style="color: rgba(255,255,255,0.5);">Created:</strong> @Model.CreatedAt.ToString("dd MMM yyyy")</p>

            <!-- Warning about cascade deletion of related records -->
            <div style="background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 10px; padding: 14px; margin: 20px 0; font-size: 0.85rem; color: rgba(255,255,255,0.6);">
                Deleting this project will also remove all associated comments, milestones, collaboration requests and celebration entries.
            </div>

            <!-- Confirmation form - posts to ProjectsController.Delete (POST) -->
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                <div style="display: flex; gap: 12px;">
                    <input type="submit" value="Yes, Delete Project" class="btn btn-danger" />
                    <!-- Cancel returns to the project details page without deleting -->
                    @Html.ActionLink("Cancel", "Details", new { id = Model.ProjectId }, new { @class = "btn btn-default" })
                </div>
            }

        </div>
    </div>
</div>