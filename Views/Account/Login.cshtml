@using MzansiBuilds.Models
@model LoginViewModel

@{
    ViewBag.Title = "Log In";
}

<!-- Centered login card layout -->
<div style="min-height: 85vh; display: flex; align-items: center; justify-content: center; padding: 40px 0;">
    <div style="width: 100%; max-width: 440px;">

        <!-- Page heading -->
        <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="font-size: 2.2rem; margin-bottom: 6px;">Welcome <span class="green-text">back</span></h2>
            <p style="font-size: 0.9rem" class="text-muted">Log in to your MzansiBuilds account</p>
        </div>

        <div class="panel panel-default">
            <div class="panel-body" style="padding: 20px;">

                <!-- Login form - posts to AccountController.Login, includes CSRF token -->
                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
                {
                    @Html.AntiForgeryToken()

                    <!-- Server-side validation errors displayed here (excludes field-level messages) -->
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <!-- Email field -->
                    <div style="margin-bottom: 20px;">
                        @Html.LabelFor(m => m.Email, new { @class = "control-label" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "you@example.com" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>

                    <!-- Password field with eye toggle button -->
                    <div style="margin-bottom: 20px;">
                        @Html.LabelFor(m => m.Password, new { @class = "control-label" })
                        <div style="position: relative;">
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Your password", id = "loginPassword", style = "padding-right: 42px;" })
                            <!-- Toggle password visibility - calls togglePassword() in script below -->
                            <button type="button" onclick="togglePassword('loginPassword', this)"
                                    style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: rgba(255,255,255,0.35); cursor: pointer; padding: 0; font-size: 0.9rem;">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>

                    <!-- Remember me checkbox - controls session persistence -->
                    <div style="margin-bottom: 24px;">
                        <div class="checkbox" style="margin: 0;">
                            <label style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">
                                @Html.CheckBoxFor(m => m.RememberMe) Remember me
                            </label>
                        </div>
                    </div>

                    <input type="submit" value="Log In" class="btn btn-primary" style="width: 100%; padding: 11px; font-size: 0.95rem;" />
                }

                <!-- Link to registration page -->
                <div style="text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.06);">
                    <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem; margin: 0;">
                        Don't have an account? @Html.ActionLink("Register here", "Register", "Account")
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <!-- Toggles password field between text and password type, swaps eye icon accordingly -->
    <script>
        function togglePassword(fieldId, btn) {
            var field = document.getElementById(fieldId);
            var icon = btn.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
                btn.style.color = 'rgba(255,255,255,0.7)';
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
                btn.style.color = 'rgba(255,255,255,0.35)';
            }
        }
    </script>
}