@{
    ViewBag.Title = "Home";
}

<!-- Full-height flex layout centres content vertically on the landing page -->
<div style="display: flex; flex-direction: column; justify-content: center; min-height: calc(100vh - 90px); padding: 0;">

    <!-- Hero section -->
    <div style="text-align: center; margin-bottom: 40px;">

        <!-- Community pill badge -->
        <div style="display: inline-block; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); border-radius: 20px; padding: 5px 16px; font-size: 0.72rem; font-weight: 700; color: #22c55e; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 22px;">
            Build in Public &middot; South Africa
        </div>

        <h1 style="font-family: 'Space Grotesk', sans-serif; font-size: 2.8rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 16px; line-height: 1.15; color: #fff;">
            Where developers<br><span style="color: #22c55e;">build in public</span>
        </h1>

        <p style="font-size: 0.95rem; color: rgba(255,255,255,0.48); max-width: 480px; margin: 0 auto 28px auto; line-height: 1.75;">
            Share your projects, log milestones, get feedback and collaborate with other developers in the Mzansi community.
        </p>

        <!-- CTA buttons - Join only shown to unauthenticated visitors -->
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
            @Html.ActionLink("Explore Projects", "Index", "Projects", null, new { @class = "btn btn-primary", style = "padding: 11px 28px; font-size: 0.92rem;" })
            @if (!Request.IsAuthenticated)
            {
                @Html.ActionLink("Join the Community", "Register", "Account", null, new { @class = "btn btn-default", style = "padding: 11px 28px; font-size: 0.92rem;" })
            }
        </div>

    </div>

    <!-- Feature cards - four-column grid summarising the platform's core features -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">

        <div class="panel panel-default" style="margin-bottom: 0;">
            <div class="panel-body" style="padding: 24px 22px;">
                <div style="width: 40px; height: 40px; background: rgba(34,197,94,0.1); border-radius: 10px; margin-bottom: 16px; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-rocket" style="color: #22c55e; font-size: 1rem;"></i>
                </div>
                <h4 style="color: #fff; margin-bottom: 8px; font-size: 0.92rem;">Build in Public</h4>
                <p style="font-size: 0.82rem; margin: 0; line-height: 1.65; color: rgba(255,255,255,0.48);">Share what you are building with the community. Progress over perfection.</p>
            </div>
        </div>

        <div class="panel panel-default" style="margin-bottom: 0;">
            <div class="panel-body" style="padding: 24px 22px;">
                <div style="width: 40px; height: 40px; background: rgba(34,197,94,0.1); border-radius: 10px; margin-bottom: 16px; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-flag-checkered" style="color: #22c55e; font-size: 1rem;"></i>
                </div>
                <h4 style="color: #fff; margin-bottom: 8px; font-size: 0.92rem;">Log Milestones</h4>
                <p style="font-size: 0.82rem; margin: 0; line-height: 1.65; color: rgba(255,255,255,0.48);">Keep a journal of your progress so others can follow your journey.</p>
            </div>
        </div>

        <div class="panel panel-default" style="margin-bottom: 0;">
            <div class="panel-body" style="padding: 24px 22px;">
                <div style="width: 40px; height: 40px; background: rgba(34,197,94,0.1); border-radius: 10px; margin-bottom: 16px; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-handshake" style="color: #22c55e; font-size: 1rem;"></i>
                </div>
                <h4 style="color: #fff; margin-bottom: 8px; font-size: 0.92rem;">Collaborate</h4>
                <p style="font-size: 0.82rem; margin: 0; line-height: 1.65; color: rgba(255,255,255,0.48);">Send collaboration requests and build together with other developers.</p>
            </div>
        </div>

        <div class="panel panel-default" style="margin-bottom: 0;">
            <div class="panel-body" style="padding: 24px 22px;">
                <div style="width: 40px; height: 40px; background: rgba(34,197,94,0.1); border-radius: 10px; margin-bottom: 16px; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-trophy" style="color: #22c55e; font-size: 1rem;"></i>
                </div>
                <h4 style="color: #fff; margin-bottom: 8px; font-size: 0.92rem;">Celebrate Wins</h4>
                <p style="font-size: 0.82rem; margin: 0; line-height: 1.65; color: rgba(255,255,255,0.48);">Completed projects get featured on the Celebration Wall.</p>
            </div>
        </div>

    </div>

</div>