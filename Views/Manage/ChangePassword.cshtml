@model MzansiBuilds.Models.ChangePasswordViewModel

@{
    ViewBag.Title = "Change Password";
}

<!-- Constrained width for a focused form layout -->
<div style="max-width: 500px; margin: 0 auto;">

    <!-- Page heading -->
    <div class="page-hero" style="margin-bottom: 20px;">
        <h2>Change <span class="green-text">Password</span></h2>
        <p>Update your account password</p>
    </div>

    <div class="panel panel-default">
        <div class="panel-body" style="padding: 28px;">

            <!-- Change password form - posts to ManageController.ChangePassword (POST) -->
            @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()
                <!-- Validation summary shows all field errors at the top -->
                @Html.ValidationSummary("", new { @class = "text-danger" })

                <!-- Current password field with eye toggle -->
                <div style="margin-bottom: 18px;">
                    <label class="control-label">Current Password</label>
                    <div style="position: relative; margin-top: 6px;">
                        @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", placeholder = "Your current password", id = "oldPwd", style = "padding-right: 42px;" })
                        <button type="button" onclick="togglePassword('oldPwd', this)" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: rgba(255,255,255,0.35); cursor: pointer; padding: 0; font-size: 0.9rem;">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "text-danger" })
                </div>

                <!-- New password field with eye toggle -->
                <div style="margin-bottom: 18px;">
                    <label class="control-label">New Password</label>
                    <div style="position: relative; margin-top: 6px;">
                        @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", placeholder = "Min. 8 characters", id = "newPwd", style = "padding-right: 42px;" })
                        <button type="button" onclick="togglePassword('newPwd', this)" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: rgba(255,255,255,0.35); cursor: pointer; padding: 0; font-size: 0.9rem;">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger" })
                </div>

                <!-- Confirm new password field with eye toggle -->
                <div style="margin-bottom: 28px;">
                    <label class="control-label">Confirm New Password</label>
                    <div style="position: relative; margin-top: 6px;">
                        @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Repeat new password", id = "confirmPwd", style = "padding-right: 42px;" })
                        <button type="button" onclick="togglePassword('confirmPwd', this)" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: rgba(255,255,255,0.35); cursor: pointer; padding: 0; font-size: 0.9rem;">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                </div>

                <!-- Form action buttons - Cancel returns to profile without saving -->
                <div style="display: flex; gap: 12px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.05);">
                    <input type="submit" value="Change Password" class="btn btn-primary" />
                    @Html.ActionLink("Cancel", "Index", "Profile", null, new { @class = "btn btn-default" })
                </div>
            }

        </div>
    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <!-- Toggles password field between text and password type, swaps eye icon accordingly -->
    <script>
        function togglePassword(fieldId, btn) {
            var field = document.getElementById(fieldId);
            var icon = btn.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
                btn.style.color = 'rgba(255,255,255,0.7)';
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
                btn.style.color = 'rgba(255,255,255,0.35)';
            }
        }
    </script>
}